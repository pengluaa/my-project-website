---
import profile from '../data/profile.json';

const navLinks = [
	{ href: '/', label: '首页' },
	{ href: '/#projects', label: '项目' },
	{ href: '/#about', label: '关于' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav-header">
	<div class="container nav-inner">
		<a href="/" class="nav-logo" aria-label="首页">
			<span class="logo-bracket">[</span>
			<span class="logo-text">{profile.name}</span>
			<span class="logo-bracket">]</span>
		</a>

		<nav aria-label="主导航">
			<ul class="nav-links">
				{
					navLinks.map(({ href, label }) => (
						<li>
							<a
								href={href}
								class:list={[
									'nav-link',
									{
										active:
											currentPath === href &&
											href !== '/#projects' &&
											href !== '/#about',
									},
								]}
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<a href={'mailto:' + profile.email} class="nav-cta"> 联系我 → </a>
	</div>
</header>

<style>
	.nav-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(245, 242, 235, 0.85);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}

	.nav-inner {
		display: flex;
		align-items: center;
		gap: 2rem;
		height: 64px;
	}

	.nav-logo {
		font-family: var(--font-mono);
		font-size: 1rem;
		font-weight: 500;
		letter-spacing: 0.05em;
		color: var(--ink);
		transition: opacity 0.2s;
		flex-shrink: 0;
	}

	.nav-logo:hover {
		opacity: 0.6;
	}

	.logo-bracket {
		color: var(--accent);
	}

	.logo-text {
		padding: 0 0.15em;
	}

	nav {
		margin-left: auto;
	}

	.nav-links {
		display: flex;
		gap: 0.25rem;
		list-style: none;
	}

	.nav-link {
		font-size: 0.875rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		padding: 0.4em 0.75em;
		border-radius: 4px;
		color: var(--muted);
		transition:
			color 0.2s,
			background 0.2s;
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--ink);
		background: var(--paper-2);
	}

	.nav-cta {
		font-size: 0.8125rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		padding: 0.5em 1.1em;
		background: var(--ink);
		color: var(--paper);
		border-radius: 4px;
		transition:
			background 0.2s,
			transform 0.15s;
		flex-shrink: 0;
		white-space: nowrap;
	}

	.nav-cta:hover {
		background: var(--accent);
		transform: translateY(-1px);
	}

	@media (max-width: 600px) {
		.nav-links {
			display: none;
		}
		nav {
			margin-left: auto;
		}
		.nav-cta {
			font-size: 0.75rem;
			padding: 0.45em 0.9em;
		}
	}
</style>
