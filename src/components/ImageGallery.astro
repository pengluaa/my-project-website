---
interface Props {
  images: string[];
  title: string;
}

const { images, title } = Astro.props;
---

{images.length > 0 && (
  <div class="gallery" data-count={images.length}>
    {images.length === 1 ? (
      <div class="gallery-single">
        <img src={images[0]} alt={`${title} 截图`} loading="lazy" />
      </div>
    ) : images.length === 2 ? (
      <div class="gallery-two">
        {images.map((img, i) => (
          <div class="gallery-item">
            <img src={img} alt={`${title} 截图 ${i + 1}`} loading="lazy" />
          </div>
        ))}
      </div>
    ) : (
      <div class="gallery-grid">
        <div class="gallery-main">
          <img src={images[0]} alt={`${title} 主图`} loading="lazy" />
        </div>
        <div class="gallery-side">
          {images.slice(1, 3).map((img, i) => (
            <div class="gallery-item">
              <img src={img} alt={`${title} 截图 ${i + 2}`} loading="lazy" />
            </div>
          ))}
        </div>
        {images.length > 3 && (
          <div class="gallery-more">
            <div class="gallery-item gallery-item--more">
              <img src={images[3]} alt={`${title} 截图 4`} loading="lazy" />
              <div class="more-overlay">
                <span>+{images.length - 3} 张</span>
              </div>
            </div>
          </div>
        )}
      </div>
    )}
  </div>
)}

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog">
  <button class="lightbox-close" id="lightbox-close" aria-label="关闭">✕</button>
  <button class="lightbox-prev" id="lightbox-prev" aria-label="上一张">←</button>
  <button class="lightbox-next" id="lightbox-next" aria-label="下一张">→</button>
  <div class="lightbox-content">
    <img id="lightbox-img" src="" alt="" />
  </div>
  <div class="lightbox-counter" id="lightbox-counter"></div>
</div>

<script define:vars={{ images, title }}>
  const allImages = images;
  let current = 0;

  const lightbox = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img');
  const lbCounter = document.getElementById('lightbox-counter');

  function openLightbox(index) {
    current = index;
    lbImg.src = allImages[current];
    lbImg.alt = `${title} 截图 ${current + 1}`;
    lbCounter.textContent = `${current + 1} / ${allImages.length}`;
    lightbox.setAttribute('aria-hidden', 'false');
    lightbox.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    lightbox.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function prevImage() {
    current = (current - 1 + allImages.length) % allImages.length;
    lbImg.src = allImages[current];
    lbCounter.textContent = `${current + 1} / ${allImages.length}`;
  }

  function nextImage() {
    current = (current + 1) % allImages.length;
    lbImg.src = allImages[current];
    lbCounter.textContent = `${current + 1} / ${allImages.length}`;
  }

  document.querySelectorAll('.gallery img').forEach((img, i) => {
    img.style.cursor = 'zoom-in';
    img.addEventListener('click', () => openLightbox(i));
  });

  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev').addEventListener('click', prevImage);
  document.getElementById('lightbox-next').addEventListener('click', nextImage);

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') prevImage();
    if (e.key === 'ArrowRight') nextImage();
  });
</script>

<style>
  .gallery { margin: 2.5rem 0; }

  /* Single image */
  .gallery-single img {
    width: 100%;
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  /* Two images */
  .gallery-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  /* Grid (3+) */
  .gallery-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto;
    gap: 0.75rem;
  }

  .gallery-main {
    grid-row: 1 / 3;
  }

  .gallery-side {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .gallery-more .gallery-item--more {
    position: relative;
  }

  .more-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.65);
    display: grid;
    place-items: center;
    border-radius: 8px;
  }

  .more-overlay span {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    font-family: var(--font-display);
  }

  /* Shared image styles */
  .gallery img,
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
    border: 1px solid var(--border);
    display: block;
    transition: opacity 0.2s;
  }

  .gallery img:hover { opacity: 0.92; }

  .gallery-main img {
    aspect-ratio: 4/3;
  }

  .gallery-side .gallery-item img {
    aspect-ratio: 4/3;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 1000;
    display: none;
    place-items: center;
    padding: 2rem;
  }

  .lightbox.is-open { display: grid; }

  .lightbox-content {
    max-width: 90vw;
    max-height: 85vh;
    position: relative;
  }

  #lightbox-img {
    max-width: 100%;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 6px;
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: fixed;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    cursor: pointer;
    border-radius: 6px;
    font-size: 1.1rem;
    transition: background 0.2s;
    z-index: 1001;
  }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(255,255,255,0.25);
  }

  .lightbox-close {
    top: 1.25rem;
    right: 1.25rem;
    padding: 0.5rem 0.75rem;
  }

  .lightbox-prev {
    left: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    padding: 0.75rem 1rem;
  }

  .lightbox-next {
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    padding: 0.75rem 1rem;
  }

  .lightbox-counter {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: rgba(255,255,255,0.6);
  }

  @media (max-width: 640px) {
    .gallery-two,
    .gallery-grid { grid-template-columns: 1fr; }
    .gallery-main { grid-row: auto; }
  }
</style>
