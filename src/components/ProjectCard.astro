---
import type { Project } from '../types/index';

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

const statusLabel: Record<Project['status'], string> = {
  active: '进行中',
  completed: '已完成',
  archived: '已归档',
};
---

<article
  class="project-card"
  style={`animation-delay: ${index * 80}ms`}
>
  <a href={`/projects/${project.slug}`} class="card-link" aria-label={`查看项目：${project.title}`}>
    <div class="card-image-wrap">
      {project.coverImage ? (
        <img
          src={project.coverImage}
          alt={project.title}
          class="card-image"
          loading="lazy"
          width="600"
          height="360"
        />
      ) : (
        <div class="card-image-placeholder">
          <span class="placeholder-text">{project.title.charAt(0)}</span>
        </div>
      )}
      <div class="card-overlay">
        <span class="card-view-cta">查看详情 →</span>
      </div>
    </div>

    <div class="card-body">
      <div class="card-meta">
        <span class={`status-dot status-${project.status}`}></span>
        <span class="card-status">{statusLabel[project.status]}</span>
        <span class="card-period">{project.startDate}{project.endDate ? ` — ${project.endDate}` : ' — 至今'}</span>
      </div>

      <h3 class="card-title">{project.title}</h3>
      <p class="card-summary">{project.summary}</p>

      <div class="card-tags">
        {project.tags.slice(0, 4).map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </a>

  {project.githubUrl && (
    <a
      href={project.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="card-github"
      aria-label="在 GitHub 查看源码"
      onclick="event.stopPropagation()"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
      <span>源码</span>
    </a>
  )}
</article>

<style>
  .project-card {
    position: relative;
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    animation: fadeUp 0.5s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.1);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .card-image-wrap {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--paper-2);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .project-card:hover .card-image {
    transform: scale(1.04);
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--paper-2) 0%, var(--border) 100%);
  }

  .placeholder-text {
    font-family: var(--font-display);
    font-size: 4rem;
    color: var(--muted);
    opacity: 0.4;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.65);
    display: grid;
    place-items: center;
    opacity: 0;
    transition: opacity 0.25s;
  }

  .project-card:hover .card-overlay { opacity: 1; }

  .card-view-cta {
    font-size: 0.9375rem;
    font-weight: 600;
    color: white;
    letter-spacing: 0.03em;
    padding: 0.6em 1.2em;
    border: 1.5px solid rgba(255,255,255,0.6);
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }

  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.7rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-active { background: #22c55e; }
  .status-completed { background: #3b82f6; }
  .status-archived { background: var(--muted); }

  .card-status {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted);
  }

  .card-period {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--border);
    margin-left: auto;
  }

  .card-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.25em 0.65em;
    background: var(--paper-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--muted);
  }

  .card-github {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-mono);
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    border: 1px solid var(--border);
    color: var(--ink);
    padding: 0.3em 0.7em;
    border-radius: 5px;
    transition: background 0.2s, transform 0.15s;
    z-index: 2;
  }

  .card-github:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
    transform: scale(1.04);
  }
</style>
