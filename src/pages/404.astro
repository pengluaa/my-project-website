---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — 页面不存在">
  <div class="not-found">
    <div class="container">
      <p class="not-found-code">404</p>
      <h1 class="not-found-title">页面走丢了</h1>
      <p class="not-found-desc">这个页面不存在，也许你想找的在别处？</p>
      <a href="/" class="not-found-btn">← 回到首页</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    text-align: center;
  }

  .not-found .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .not-found-code {
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 12rem);
    line-height: 1;
    color: var(--paper-2);
    letter-spacing: -0.05em;
  }

  .not-found-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .not-found-desc {
    color: var(--muted);
    font-size: 1rem;
  }

  .not-found-btn {
    margin-top: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.65em 1.5em;
    background: var(--ink);
    color: var(--paper);
    border-radius: 5px;
    transition: background 0.2s;
  }

  .not-found-btn:hover { background: var(--accent); }
</style>
