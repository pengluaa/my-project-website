---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageGallery from '../../components/ImageGallery.astro';
import type { Project } from '../../types/index';
import projectsData from '../../data/projects.json';
import { marked } from 'marked';

export async function getStaticPaths() {
  return (projectsData as Project[]).map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props { project: Project }
const { project } = Astro.props as Props;

// Render markdown description
const descriptionHtml = marked(project.description ?? '');

const statusLabel: Record<Project['status'], string> = {
  active: '进行中',
  completed: '已完成',
  archived: '已归档',
};
---

<BaseLayout
  title={`${project.title} — 项目详情`}
  description={project.summary}
  ogImage={project.coverImage}
>
  <div class="project-page">

    <!-- Back -->
    <div class="container back-row">
      <a href="/#projects" class="back-link">
        ← 返回所有项目
      </a>
    </div>

    <!-- Header -->
    <header class="project-header">
      <div class="container project-header-inner">
        <div class="project-meta-row">
          <span class={`status-badge status-${project.status}`}>
            <span class="status-dot-sm"></span>
            {statusLabel[project.status]}
          </span>
          <span class="project-period">
            {project.startDate}{project.endDate ? ` — ${project.endDate}` : ' — 至今'}
          </span>
        </div>

        <h1 class="project-title">{project.title}</h1>
        <p class="project-summary">{project.summary}</p>

        <div class="project-links">
          {project.githubUrl && (
            <a href={project.githubUrl} target="_blank" rel="noopener" class="link-btn link-btn--primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              查看源码
            </a>
          )}
          {project.liveUrl && (
            <a href={project.liveUrl} target="_blank" rel="noopener" class="link-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              在线预览
            </a>
          )}
        </div>

        <div class="project-tags">
          {project.tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </header>

    <!-- Tech Stack Banner -->
    <div class="tech-banner">
      <div class="container tech-banner-inner">
        <span class="tech-label">技术栈</span>
        <div class="tech-items">
          {project.techStack.map(tech => (
            <span class="tech-item">{tech}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Content -->
    <div class="container content-layout">

      <!-- Gallery -->
      <ImageGallery images={project.images} title={project.title} />

      <!-- Description (Markdown) -->
      <article class="prose" set:html={descriptionHtml} />

    </div>

    <!-- Next/Prev navigation -->
    <div class="container project-nav">
      <a href="/#projects" class="project-nav-back">
        ← 返回项目列表
      </a>
    </div>

  </div>
</BaseLayout>

<style>
  .project-page { padding-bottom: 5rem; }

  .back-row {
    padding-top: 1.5rem;
    padding-bottom: 0;
  }

  .back-link {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--muted);
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--ink); }

  /* Header */
  .project-header {
    padding: clamp(2.5rem, 6vw, 5rem) 0 clamp(2rem, 4vw, 3.5rem);
    border-bottom: 1px solid var(--border);
  }

  .project-meta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    padding: 0.3em 0.8em;
    border: 1px solid var(--border);
    border-radius: 2rem;
    background: white;
    color: var(--muted);
  }

  .status-dot-sm {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  .status-active .status-dot-sm { background: #22c55e; }
  .status-completed .status-dot-sm { background: #3b82f6; }

  .project-period {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted);
  }

  .project-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1rem;
    max-width: 18ch;
  }

  .project-summary {
    font-size: 1.125rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: 1.75rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.6em 1.25em;
    border: 1.5px solid var(--border);
    border-radius: 5px;
    color: var(--muted);
    transition: border-color 0.2s, color 0.2s;
  }

  .link-btn:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  .link-btn--primary {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  .link-btn--primary:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    padding: 0.3em 0.7em;
    background: var(--paper-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--muted);
  }

  /* Tech Banner */
  .tech-banner {
    background: var(--ink);
    padding: 1rem 0;
  }

  .tech-banner-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .tech-label {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245,242,235,0.4);
    flex-shrink: 0;
  }

  .tech-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-item {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    font-weight: 500;
    padding: 0.3em 0.8em;
    background: rgba(245,242,235,0.08);
    border: 1px solid rgba(245,242,235,0.15);
    border-radius: 3px;
    color: var(--paper);
  }

  /* Content */
  .content-layout {
    padding-top: 3rem;
    max-width: 820px;
  }

  /* Project nav */
  .project-nav {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .project-nav-back {
    font-size: 0.875rem;
    font-family: var(--font-mono);
    color: var(--muted);
    transition: color 0.2s;
  }

  .project-nav-back:hover { color: var(--ink); }
</style>
