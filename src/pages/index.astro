---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import type { Project } from '../types/index';
import projectsData from '../data/projects.json';
import profile from '../data/profile.json';

const projects = projectsData as Project[];
const featuredProjects = projects.filter(p => p.featured);
const otherProjects = projects.filter(p => !p.featured);
---

<BaseLayout title={`${profile.name} — ${profile.title}`} description={profile.bio}>
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>可接受新机会</span>
      </div>

      <h1 class="hero-name">
        {profile.name}
      </h1>

      <div class="hero-divider"></div>

      <p class="hero-title">{profile.title}</p>
      <p class="hero-bio">{profile.bio}</p>

      <div class="hero-actions">
        <a href="#projects" class="btn-primary">
          查看项目
        </a>
        <a href={profile.github} target="_blank" rel="noopener" class="btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
        <!-- <a href={`mailto:${profile.email}`} class="btn-ghost">
          邮件联系
        </a> -->
      </div>

      <div class="hero-tags">
        {profile.skills.flatMap(g => g.items).slice(0, 8).map(skill => (
          <span class="skill-pill">{skill}</span>
        ))}
        <span class="skill-pill skill-pill--more">+更多</span>
      </div>
    </div>

    <div class="hero-number" aria-hidden="true">
      {String(projects.length).padStart(2, '0')}
    </div>
  </section>

  <!-- 项目 -->
  <section class="projects-section" id="projects">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">精选项目</h2>
        <p class="section-subtitle">每个项目背后都有一个值得讲述的故事</p>
      </div>

      <div class="projects-grid featured">
        {featuredProjects.map((project, i) => (
          <ProjectCard project={project} index={i} />
        ))}
      </div>

      {otherProjects.length > 0 && (
        <>
          <h3 class="subsection-title">其他项目</h3>
          <div class="projects-grid">
            {otherProjects.map((project, i) => (
              <ProjectCard project={project} index={i} />
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <!-- 关于  -->
  <section class="about-section" id="about">
    <div class="container">
      <div class="about-grid">
        <!-- 技术栈  -->
        <div class="about-skills">
          <h2 class="section-title">技术栈</h2>
          <div class="skill-groups">
            {profile.skills.map(group => (
              <div class="skill-group">
                <h4 class="skill-group-title">{group.category}</h4>
                <div class="skill-items">
                  {group.items.map(item => (
                    <span class="skill-item">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- 工作经历 -->
        <div class="about-right">
          <div class="experience-block">
            <h2 class="section-title">工作经历</h2>
            <div class="timeline">
              {profile.experience.map((exp) => (
                <div class="timeline-item">
                  <div class="timeline-period">{exp.period}</div>
                  <div class="timeline-content">
                    <h4 class="timeline-role">{exp.role}</h4>
                    <p class="timeline-company">{exp.company}</p>
                    <p class="timeline-desc">{exp.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="education-block">
            <h2 class="section-title">教育背景</h2>
            <div class="timeline">
              {profile.education.map((edu) => (
                <div class="timeline-item">
                  <div class="timeline-period">{edu.period}</div>
                  <div class="timeline-content">
                    <h4 class="timeline-role">{edu.degree}</h4>
                    <p class="timeline-company">{edu.school}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <h2 class="cta-title">有好的项目，<br /><em>一起聊聊？</em></h2>
        <a href={`mailto:${profile.email}`} class="cta-btn">
          发送邮件 →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    padding: clamp(5rem, 12vw, 10rem) 0 clamp(4rem, 8vw, 7rem);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 760px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--muted);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.5s ease both;
  }

  .eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
  }

  .hero-name {
    font-size: clamp(3rem, 8vw, 6.5rem);
    letter-spacing: -0.035em;
    line-height: 1;
    margin-bottom: 1rem;
    animation: fadeUp 0.5s 0.05s ease both;
  }

  .hero-divider {
    width: 3rem;
    height: 3px;
    background: var(--accent);
    margin-bottom: 1.25rem;
    animation: expandW 0.6s 0.15s ease both;
  }

  @keyframes expandW {
    from { width: 0; }
    to   { width: 3rem; }
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--muted);
    letter-spacing: 0.03em;
    margin-bottom: 1rem;
    animation: fadeUp 0.5s 0.1s ease both;
  }

  .hero-bio {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.7;
    color: var(--ink);
    max-width: 54ch;
    margin-bottom: 2rem;
    animation: fadeUp 0.5s 0.15s ease both;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
    animation: fadeUp 0.5s 0.2s ease both;
  }

  .btn-primary {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.65em 1.5em;
    background: var(--ink);
    color: var(--paper);
    border-radius: 5px;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover {
    background: var(--accent);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.65em 1.3em;
    border: 1.5px solid var(--border);
    border-radius: 5px;
    color: var(--muted);
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    animation: fadeUp 0.5s 0.25s ease both;
  }

  .skill-pill {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    padding: 0.3em 0.8em;
    background: var(--paper-2);
    border: 1px solid var(--border);
    border-radius: 2rem;
    color: var(--muted);
  }

  .skill-pill--more {
    color: var(--accent);
    border-color: var(--accent-soft);
    background: var(--accent-soft);
  }

  .hero-number {
    position: absolute;
    right: -0.05em;
    bottom: -0.2em;
    font-family: var(--font-display);
    font-size: clamp(10rem, 22vw, 18rem);
    line-height: 1;
    color: var(--paper-2);
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
    z-index: 0;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== PROJECTS ===== */
  .projects-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .section-header {
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.4rem;
  }

  .section-subtitle {
    font-size: 0.9375rem;
    color: var(--muted);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .projects-grid.featured {
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
  }

  .subsection-title {
    font-size: 1.125rem;
    font-family: var(--font-mono);
    color: var(--muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  /* ===== ABOUT ===== */
  .about-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
    border-top: 1px solid var(--border);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.75rem;
  }

  .skill-group-title {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-item {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.3em 0.75em;
    background: white;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--ink);
    transition: border-color 0.2s, background 0.2s;
  }

  .skill-item:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .experience-block { margin-top: 0; }
  .education-block { margin-top: 2.5rem; }

  .timeline {
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1rem;
  }

  .timeline-period {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--muted);
    padding-top: 0.2em;
    line-height: 1.5;
  }

  .timeline-role {
    font-size: 1.0625rem;
    font-family: var(--font-display);
    margin-bottom: 0.2rem;
  }

  .timeline-company {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 0.4rem;
  }

  .timeline-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.65;
  }

  /* ===== CTA ===== */
  .cta-section {
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
    padding: clamp(2.5rem, 5vw, 4rem);
    background: var(--ink);
    border-radius: 14px;
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--paper);
    letter-spacing: -0.03em;
  }

  .cta-title em {
    font-style: italic;
    color: var(--accent);
  }

  .cta-btn {
    display: inline-block;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.85em 2em;
    background: var(--paper);
    color: var(--ink);
    border-radius: 6px;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
  }

  .cta-btn:hover {
    background: var(--accent);
    color: white;
    transform: translateY(-2px);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
    .projects-grid,
    .projects-grid.featured { grid-template-columns: 1fr; }
    .hero-number { font-size: 40vw; }
    .timeline-item { grid-template-columns: 80px 1fr; }
  }
</style>
